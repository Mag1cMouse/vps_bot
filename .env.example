BOT_TOKEN=123456:telegram-token
ADMIN_IDS=123456789
BOT_PROFILE=prod
MC_CONTROL_MODE=systemd
MC_SERVICE=minecraft.service
MC_LATEST_LOG=/root/server/logs/latest.log
